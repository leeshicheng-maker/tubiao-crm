// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户相关
// ============================================

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  contactId    String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relationships
  contact      Contact?  @relation("UserContact")
  ownedNodes   Node[]    @relation("NodeOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  ownedProjects Project[] @relation("ProjectOwner")
  assignedTasks Task[]    @relation("TaskAssignee")
}

enum UserRole {
  ADMIN
  USER
  VIEWER
}

// ============================================
// 联系人
// ============================================

model Contact {
  id          String   @id @default(cuid())
  name        String
  title       String?
  organization String?
  phone       String?
  email       String?
  wechat      String?
  tags        String[] // 使用数组存储标签
  notes       String?  @db.Text
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  // Relationships
  user        User?    @relation("UserContact")

  @@index([name])
  @@index([organization])
}

// ============================================
// 超级节点（超级个人/组织）
// ============================================

model Node {
  id          String     @id @default(cuid())
  name        String
  type        NodeType
  industry    String?
  location    String?
  level       String?
  strength    String?    // 优势领域
  resources   String[]   // 资源列表
  contactId   String?    // 主要联系人
  ownerId     String
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  // Relationships
  owner       User       @relation("NodeOwner", fields: [ownerId], references: [id])
  contact     Contact?   @relation(fields: [contactId], references: [id])
  opportunities Opportunity[] @relation("SourceNode")
  projects    Project[]  @relation("SourceNodeProject")

  @@index([type])
  @@index([industry])
  @@index([ownerId])
}

enum NodeType {
  INDIVIDUAL
  ORGANIZATION
}

// ============================================
// 机会
// ============================================

model Opportunity {
  id          String          @id @default(cuid())
  title       String
  sourceNodeId String
  industry    String?
  budgetRange String?         // "100-300万" 这种字符串格式存储
  urgency     UrgencyLevel
  status      OpportunityStatus @default(NEW)
  ownerId     String
  notes       String?         @db.Text
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  // Relationships
  owner       User            @relation("OpportunityOwner", fields: [ownerId], references: [id])
  sourceNode  Node            @relation("SourceNode", fields: [sourceNodeId], references: [id])
  project     Project?        @relation("OpportunityProject")
  interactions Interaction[]  @relation("OpportunityInteractions")

  @@index([status])
  @@index([ownerId])
  @@index([sourceNodeId])
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportunityStatus {
  NEW
  ASSESSING
  ADVANCING
  CONVERTED
  CLOSED
}

// ============================================
// 项目
// ============================================

model Project {
  id                String         @id @default(cuid())
  opportunityId     String?        @unique
  title             String?
  stage             ProjectStage   @default(SCREENING)
  sourceNodeId      String?
  ownerId           String
  probability       Int?           // 成功概率 0-100
  estimatedRevenue  String?        // 预估收入（金额区间）
  startDate         DateTime?
  endDate           DateTime?
  nextAction        String?
  nextActionDueAt   DateTime?
  isArchived        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Audit
  createdBy         String?
  updatedBy         String?

  // Relationships
  opportunity       Opportunity?   @relation("OpportunityProject", fields: [opportunityId], references: [id])
  owner             User           @relation("ProjectOwner", fields: [ownerId], references: [id])
  sourceNode        Node?          @relation("SourceNodeProject", fields: [sourceNodeId], references: [id])
  interactions      Interaction[]  @relation("ProjectInteractions")

  @@index([stage])
  @@index([ownerId])
  @@index([nextActionDueAt])
}

enum ProjectStage {
  SCREENING   // 初筛
  CONTACT     // 接触
  PROPOSAL    // 提案
  NEGOTIATION // 商务谈判
  WON         // 成功
  LOST        // 失败
}

// ============================================
// 跟进记录
// ============================================

model Interaction {
  id          String           @id @default(cuid())
  type        InteractionType
  title       String
  content     String          @db.Text
  targetType  TargetType
  targetId    String           // 可以是 OpportunityID 或 ProjectID
  userId      String
  occurredAt  DateTime         @default(now())
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  // Relationships
  opportunity Opportunity?     @relation("OpportunityInteractions", fields: [targetId], references: [id])
  project     Project?         @relation("ProjectInteractions", fields: [targetId], references: [id])

  @@index([targetType, targetId])
  @@index([occurredAt])
}

enum InteractionType {
  CALL
  MEETING
  MESSAGE
  EMAIL
  NOTE
}

enum TargetType {
  OPPORTUNITY
  PROJECT
}

// ============================================
// 任务
// ============================================

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus  @default(PENDING)
  dueDate     DateTime?
  assignedTo  String
  targetType  TargetType?
  targetId    String?
  isArchived  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  // Relationships
  assignee    User        @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([dueDate])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// 资料库
// ============================================

model CapabilityAsset {
  id          String    @id @default(cuid())
  title       String
  category    String?
  type        AssetType
  url         String?
  content     String?   @db.Text
  tags        String[]
  isPublic    Boolean   @default(false)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Audit
  createdBy   String?
  updatedBy   String?

  @@index([category])
  @@index([type])
}

enum AssetType {
  DOCUMENT
  TEMPLATE
  BEST_PRACTICE
  VIDEO
  LINK
}
