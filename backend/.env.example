# ============================================
# 图标CRM 后端环境变量
# ============================================
# 复制本文件为 .env，填入真实值

# PostgreSQL 连接串
# Supabase: 在 Settings > Database > Connection string > URI 找到
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres"

# JWT 密钥（随机字符串，用于签发 Bearer Token）
JWT_SECRET="your-super-secret-jwt-key-change-this"

# ============================================
# Telegram Bot（机器人推送用）
# ============================================
# 找 @BotFather 创建 Bot，拿到 token
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# 你的 Telegram Chat ID（发消息给 @userinfobot 可获取）
TELEGRAM_CHAT_ID="your-chat-id"

# ============================================
# 机器人配置
# ============================================
# CRM API 地址（本地开发）
CRM_API_BASE="http://localhost:3000/api/v1"
# 机器人专用 API Token（系统账号的 JWT）
CRM_API_TOKEN=""
# 机器人默认归属用户 ID（prisma 里的 User.id）
BOT_USER_ID=""
# 采集来源节点 ID（代表"系统自动发现"的节点）
BOT_SOURCE_NODE_ID=""
